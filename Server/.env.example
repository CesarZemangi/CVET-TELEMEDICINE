PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=cvet_db

# JWT
JWT_SECRET=your_jwt_secret_key_here

# SMTP (Gmail SMTP for demo)
# Port 587 with STARTTLS:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_AUTH=true
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="CVet Telemedicine <yourgmail@gmail.com>"
# For SSL mode instead:
# SMTP_PORT=465
# SMTP_SECURE=true
# Optional (dev only): include reset link in forgot-password API response
EXPOSE_RESET_LINK_IN_DEV=false

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
