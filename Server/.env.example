PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=cvet_db

# JWT
JWT_SECRET=your_jwt_secret_key_here

# SMTP (Nodemailer)
SMTP_HOST=10.160.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_AUTH=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="CVet Telemedicine <no-reply@cvet.com>"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
